# ─── Server ───────────────────────────────────
PYTHON_ENV=development
PORT=8001

# ─── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb://jurismind:jurismind_secret@localhost:27017/jurismind_dev?authSource=admin

# ─── Gemini ───────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── FAISS ────────────────────────────────────
FAISS_INDEX_PATH=./faiss_index

# ─── IndicTrans2 ──────────────────────────────
INDICTRANS2_MODEL_PATH=./models/indictrans2

# ─── Security ─────────────────────────────────
# Must match AI_SERVICE_SECRET in the API .env
API_SERVICE_SECRET=change-this-to-a-random-secret
